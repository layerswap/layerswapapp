{
  "name": "@layerswap/wallet-core",
  "version": "1.5.0",
  "description": "Shared wallet core for Layerswap: wallet models and types, connector icons, and the React wallet-providers registry.",
  "type": "module",
  "main": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "typings": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.js"
    },
    "./types": {
      "types": "./dist/types/types/index.d.ts",
      "default": "./dist/esm/types/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "dist/**/*"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run build:esm+types",
    "build:esm+types": "tsc --project tsconfig.json --rootDir ./src --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types && tsc-alias -p tsconfig.json --outDir ./dist/esm && tsc-alias -p tsconfig.json --outDir ./dist/types",
    "check:types": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo"
  },
  "author": "Layerswap",
  "homepage": "https://github.com/layerswap/layerswapapp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/layerswap/layerswapapp.git",
    "directory": "packages/wallet-core"
  },
  "keywords": [
    "layerswap",
    "wallet",
    "wallet-connection"
  ],
  "license": "MIT",
  "dependencies": {
    "@layerswap/utils": "workspace:^"
  },
  "peerDependencies": {
    "react": "^16.8 || ^17.0 || ^18.0 || ^19.0.0 || ^19.0.0-rc",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@types/react": "catalog:",
    "react": "catalog:",
    "zustand": "catalog:",
    "rimraf": "^5.0.0",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2"
  },
  "engines": {
    "node": ">=22"
  },
  "bugs": {
    "url": "https://github.com/layerswap/layerswapapp/issues"
  }
}
