{
  "name": "@layerswap/wallet-fuel",
  "version": "1.5.0",
  "description": "Fuel Wallet Provider for Layerswap Widget",
  "type": "module",
  "main": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "typings": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "default": "./dist/esm/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "dist/**/*"
  ],
  "scripts": {
    "build": "pnpm run clean && pnpm run build:esm+types",
    "build:esm+types": "tsc --project tsconfig.json --rootDir ./src --outDir ./dist/esm --declaration --declarationMap --declarationDir ./dist/types && tsc-alias -p tsconfig.json --outDir ./dist/esm && tsc-alias -p tsconfig.json --outDir ./dist/types",
    "check:types": "tsc --noEmit",
    "clean": "rimraf dist tsconfig.tsbuildinfo actions chains codegen experimental internal query"
  },
  "author": "Layerswap",
  "homepage": "https://github.com/layerswap/layerswapapp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/layerswap/layerswapapp.git",
    "directory": "packages/wallets/fuel"
  },
  "keywords": [
    "layerswap",
    "fuel",
    "wallet-provider"
  ],
  "license": "MIT",
  "peerDependencies": {
    "@layerswap/widget": "workspace:^",
    "@wagmi/core": "catalog:",
    "wagmi": "catalog:",
    "viem": "catalog:",
    "zustand": "catalog:"
  },
  "dependencies": {
    "@fuel-ts/account": "^0.101.3",
    "@fuel-ts/address": "^0.101.3",
    "fuels": "^0.101.3",
    "json-rpc-2.0": "1.7.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@layerswap/widget": "workspace:^",
    "zustand": "catalog:"
  },
  "engines": {
    "node": ">=22"
  },
  "directories": {
    "lib": "lib"
  },
  "bugs": {
    "url": "https://github.com/layerswap/layerswapapp/issues"
  }
}