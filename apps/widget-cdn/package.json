{
  "name": "@layerswap/widget-cdn",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "rspack serve --config rspack.config.mjs",
    "build": "rspack build --config rspack.config.mjs --mode production && node scripts/build-manifest.mjs",
    "verify-manifest": "node scripts/verify-manifest.mjs",
    "deploy:r2": "node scripts/deploy-r2.mjs",
    "rollback:r2": "node scripts/rollback-r2.mjs",
    "worker:dev": "wrangler dev --config worker/wrangler.toml",
    "worker:deploy": "wrangler deploy --config worker/wrangler.toml",
    "start": "node serve.mjs"
  },
  "dependencies": {
    "@layerswap/wallets": "workspace:^",
    "@layerswap/widget": "workspace:^",
    "@tanstack/react-query": "catalog:",
    "assert": "^2.1.0",
    "browserify-zlib": "^0.2.0",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "events": "^3.3.0",
    "https-browserify": "^1.0.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "process": "^0.11.10",
    "react": "catalog:",
    "react-dom": "catalog:",
    "stream-browserify": "^3.0.0",
    "stream-http": "^3.2.0",
    "url": "^0.11.4",
    "util": "^0.12.5",
    "viem": "catalog:",
    "vm-browserify": "^1.1.2",
    "wagmi": "catalog:",
    "zustand": "catalog:"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@module-federation/enhanced": "^0.9.0",
    "@rspack/cli": "^1.1.5",
    "@rspack/core": "^1.1.5",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "css-loader": "^7.1.2",
    "mini-css-extract-plugin": "^2.9.2",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.2",
    "wrangler": "^3.90.0"
  }
}
